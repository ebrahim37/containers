  "systemd": {
    "units": [
      {
        "contents": "[Unit]\nDescription=Layer host packages with rpm-ostree\nWants=network-online.target\nAfter=network-online.target\nBefore=zincati.service\nConditionPathExists=!/var/lib/%N.stamp\n\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/usr/bin/rpm-ostree install -y --allow-inactive qemu-guest-agent git-core\nExecStart=/bin/touch /var/lib/%N.stamp\nExecStart=/bin/systemctl --no-block reboot\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "install-host-packages.service"
      },
      {
        "enabled": true,
        "name": "qemu-guest-agent.service"
      },
      {
        "contents": "[Unit]\nDescription=Clone containers git repo for core user\nWants=network-online.target\nAfter=network-online.target install-host-packages.service\nConditionPathExists=/usr/bin/git\nConditionPathExists=!/home/core/containers-git/.git\n\n[Service]\nType=oneshot\nUser=core\nGroup=core\nWorkingDirectory=/home/core\nExecStart=/usr/bin/git clone \"https://github.com/beans42/containers.git\" /home/core/containers-git\n\n[Install]\nWantedBy=multi-user.target\n",
        "enabled": true,
        "name": "clone-containers-repo.service"
      }
    ]
  }
}
